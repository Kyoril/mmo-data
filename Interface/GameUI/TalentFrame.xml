<?xml version="1.0" ?>
<UiLayout xmlns="http://www.w3schools.com/Ui" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.w3schools.com/Ui.xsd file:///F:/mmo/data/client/Interface/Ui.xsd">
	<Script file="TalentFrame.lua" />

	<Font name="TalentTabFont" file="Fonts/FRIZQT__.TTF" size="20" outline="0" shadowX="1.0" shadowY="1.0" />
	<Font name="TalentRankFont" file="Fonts/FRIZQT__.TTF" size="15" outline="1" shadowX="0.5" shadowY="0.5" />

	<Frame name="TalentFrameTabButtonTemplate" type="Button" renderer="CheckboxRenderer">
		<Property name="Font" value="TalentTabFont" />
		<Property name="Checkable" value="true" />
		<Visual>
			<ImagerySection name="NormalFrame"><BorderComponent texture="Interface/GameUI/fg4_buttonSmall1_Down_result.htex" borderSize="25" /></ImagerySection>
			<ImagerySection name="HoverFrame"><BorderComponent texture="Interface/GameUI/fg4_buttonSmall1_Up_result.htex" borderSize="25" /></ImagerySection>
			<ImagerySection name="SelectedFrame">
				<BorderComponent texture="Interface/GameUI/fg4_buttonSmall1_Over_result.htex" borderSize="25" />
				<BorderComponent texture="Interface/GameUI/fg4_borders_insetBlackSmall.htex" borderSize="8"><Area><Inset all="5" /></Area></BorderComponent>
			</ImagerySection>
			<ImagerySection name="Caption"><TextComponent color="FFB9A26A" horzAlign="CENTER" vertAlign="CENTER" /></ImagerySection>
			<ImagerySection name="CaptionActive"><TextComponent color="FFFFFFFF" horzAlign="CENTER" vertAlign="CENTER" /></ImagerySection>
			<StateImagery name="Normal"><Layer><Section section="NormalFrame" /><Section section="Caption" /></Layer></StateImagery>
			<StateImagery name="Hovered"><Layer><Section section="HoverFrame" /><Section section="CaptionActive" /></Layer></StateImagery>
			<StateImagery name="Pushed"><Layer><Section section="SelectedFrame" /><Section section="CaptionActive" /></Layer></StateImagery>
			<StateImagery name="NormalChecked"><Layer><Section section="SelectedFrame" /><Section section="CaptionActive" /></Layer></StateImagery>
			<StateImagery name="HoveredChecked"><Layer><Section section="SelectedFrame" /><Section section="CaptionActive" /></Layer></StateImagery>
			<StateImagery name="PushedChecked"><Layer><Section section="SelectedFrame" /><Section section="CaptionActive" /></Layer></StateImagery>
		</Visual>
		<Area><Size><AbsDimension x="360" y="76" /></Size></Area>
	</Frame>

	<Frame name="TalentFrameTalentTemplate" type="Button" renderer="CheckboxRenderer">
		<Property name="Icon" />
		<Property name="Checkable" value="true" />
		<Visual>
			<ImagerySection name="NormalFrame"><BorderComponent texture="Interface/BW_ButtonSmall_Up.htex" borderSize="30" /></ImagerySection>
			<ImagerySection name="HoverFrame"><BorderComponent texture="Interface/BW_ButtonSmall_Over.htex" borderSize="30" /></ImagerySection>
			<ImagerySection name="PushedFrame"><BorderComponent texture="Interface/BW_ButtonSmall_Down.htex" borderSize="30" /></ImagerySection>
			<ImagerySection name="DisabledFrame"><BorderComponent texture="Interface/BW_ButtonSmall_Up.htex" borderSize="30" /></ImagerySection>
			<ImagerySection name="Icon"><ImageComponent><Area><Inset all="16" /></Area><PropertyValue property="Icon" /></ImageComponent></ImagerySection>
			<ImagerySection name="DisabledIcon"><ImageComponent tint="FF676B72"><Area><Inset all="16" /></Area><PropertyValue property="Icon" /></ImageComponent></ImagerySection>
			<StateImagery name="Normal"><Layer><Section section="NormalFrame" /><Section section="Icon" /></Layer></StateImagery>
			<StateImagery name="Hovered"><Layer><Section section="HoverFrame" /><Section section="Icon" /></Layer></StateImagery>
			<StateImagery name="Pushed"><Layer><Section section="PushedFrame" /><Section section="Icon" /></Layer></StateImagery>
			<StateImagery name="NormalChecked"><Layer><Section section="HoverFrame" /><Section section="Icon" /></Layer></StateImagery>
			<StateImagery name="HoveredChecked"><Layer><Section section="PushedFrame" /><Section section="Icon" /></Layer></StateImagery>
			<StateImagery name="PushedChecked"><Layer><Section section="PushedFrame" /><Section section="Icon" /></Layer></StateImagery>
			<StateImagery name="Disabled"><Layer><Section section="DisabledFrame" /><Section section="DisabledIcon" /></Layer></StateImagery>
		</Visual>
		<Area><Size><AbsDimension x="128" y="128" /></Size></Area>
		<Frame name="Rank" renderer="DefaultRenderer">
			<Property name="Font" value="TalentRankFont" />
			<Property name="TextColor" value="FFFFFFFF" />
			<Property name="Clickable" value="false" />
			<Visual>
				<ImagerySection name="Background"><BorderComponent texture="Interface/GameUI/fg4_borders_insetBlackSmall.htex" borderSize="4" tint="EE000000" /><TextComponent color="$TextColor" horzAlign="CENTER" vertAlign="CENTER" /></ImagerySection>
				<StateImagery name="Enabled"><Layer><Section section="Background" /></Layer></StateImagery>
			</Visual>
			<Area><Size><AbsDimension x="48" y="30" /></Size><Anchor point="BOTTOM" offset="-2" /><Anchor point="RIGHT" offset="-2" /></Area>
		</Frame>
	</Frame>

	<Frame name="TalentFrameLineTemplate" type="Line">
		<Property name="Texture" value="Textures/Character/T_EV_BlankWhite_01.htex" />
		<Property name="Color" value="FF4A5360" />
		<Property name="Thickness" value="5" />
		<Property name="Clickable" value="false" />
		<Property name="ClippedByParent" value="false" />
	</Frame>

	<Frame name="TalentFrame" renderer="DefaultRenderer" parent="GameParent">
		<Property name="Visible" value="false" />
		<Visual>
			<ImagerySection name="Background"><BorderComponent texture="Interface/GameUI/fg4_borders_simple.htex" borderSize="250" /></ImagerySection>
			<StateImagery name="Enabled"><Layer><Section section="Background" /></Layer></StateImagery>
		</Visual>
		<Area>
			<Size><AbsDimension x="2700" y="1720" /></Size>
			<Anchor point="H_CENTER" />
			<Anchor point="V_CENTER" />
		</Area>

		<Frame name="TalentFrameTitleBar" inherits="TitleBar">
			<Property name="Text" value="TALENTS" />
			<Area><Anchor point="TOP" offset="24" /><Anchor point="LEFT" offset="24" /><Anchor point="RIGHT" offset="-24" /></Area>
		</Frame>

		<Frame name="TalentFrameTabContainer">
			<Area><Anchor point="TOP" relativePoint="BOTTOM" relativeTo="TalentFrameTitleBar" offset="18" /><Anchor point="LEFT" offset="70" /><Anchor point="RIGHT" offset="-70" /><Size><AbsDimension y="82" /></Size></Area>
		</Frame>

		<Frame name="TalentFrameCanvasViewport" renderer="DefaultRenderer">
			<Property name="Focusable" value="true" />
			<Property name="Background" value="Interface/GameUI/TalentFrameBackground.htex" />
			<Visual>
				<ImagerySection name="Canvas">
					<ImageComponent tint="FFB7C0CB"><Area><Inset all="12" /></Area><PropertyValue property="Background" /></ImageComponent>
					<BorderComponent texture="Interface/GameUI/fg4_borders_01_19.htex" borderSize="25" />
				</ImagerySection>
				<StateImagery name="Enabled"><Layer><Section section="Canvas" /></Layer></StateImagery>
			</Visual>
			<Area><Anchor point="TOP" relativePoint="BOTTOM" relativeTo="TalentFrameTabContainer" offset="12" /><Anchor point="LEFT" offset="54" /><Anchor point="RIGHT" offset="-54" /><Anchor point="BOTTOM" offset="-150" /></Area>
			<Frame name="TalentFrameCanvasContent">
				<Property name="ClippedByParent" value="true" />
				<Property name="Clickable" value="false" />
				<Area><Size><AbsDimension x="1600" y="1200" /></Size><Anchor point="TOP" offset="0" /><Anchor point="LEFT" offset="0" /></Area>
			</Frame>
		</Frame>

		<Frame name="TalentFrameZoomOut" inherits="GlueButton"><Property name="Text" value="-" /><Area><Anchor point="BOTTOM" offset="-52" /><Anchor point="LEFT" offset="76" /><Size><AbsDimension x="88" y="70" /></Size></Area></Frame>
		<Frame name="TalentFrameZoomReset" inherits="GlueButton"><Property name="Text" value="TALENT_RESET_VIEW" /><Area><Anchor point="BOTTOM" offset="-52" /><Anchor point="LEFT" relativePoint="RIGHT" relativeTo="TalentFrameZoomOut" offset="8" /><Size><AbsDimension x="260" y="70" /></Size></Area></Frame>
		<Frame name="TalentFrameZoomIn" inherits="GlueButton"><Property name="Text" value="+" /><Area><Anchor point="BOTTOM" offset="-52" /><Anchor point="LEFT" relativePoint="RIGHT" relativeTo="TalentFrameZoomReset" offset="8" /><Size><AbsDimension x="88" y="70" /></Size></Area></Frame>

		<Frame name="TalentFramePointsText" inherits="TextSmall">
			<Property name="HorzAlign" value="CENTER" />
			<Property name="TextColor" value="FFFFD100" />
			<Area><Anchor point="BOTTOM" offset="-64" /><Anchor point="LEFT" offset="700" /><Anchor point="RIGHT" offset="-700" /><Size><AbsDimension y="56" /></Size></Area>
		</Frame>

		<Scripts>
			<OnLoad>return function(this) TalentFrame_OnLoad(this) end</OnLoad>
			<OnShow>return function(this) TalentFrame_OnShow(this) end</OnShow>
		</Scripts>
	</Frame>
</UiLayout>
