<?xml version="1.0" ?>
<UiLayout xmlns="http://www.w3schools.com/Ui" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.w3.org/2001/XMLSchema-instance http://www.w3.org/2001/XMLSchema-instance">
	<Script file="QuestTracker.lua" />

	<!-- Toggle button template -->
	<Frame name="QuestTrackerToggleTemplate" type="Button" renderer="ButtonRenderer">
		<Property name="Font" value="DefaultSmall" />
		<Property name="HorzAlign" value="CENTER" />
		<Property name="VertAlign" value="MIDDLE" />
		<Visual>
			<ImagerySection name="FrameNormal">
				<ImageComponent color="66333333" />
			</ImagerySection>
			<ImagerySection name="FrameHovered">
				<ImageComponent color="AA555555" />
			</ImagerySection>
			<ImagerySection name="FramePushed">
				<ImageComponent color="CC222222" />
			</ImagerySection>
			<ImagerySection name="TextNormal">
				<TextComponent color="FFCCCCCC" horzAlign="CENTER" vertAlign="MIDDLE" />
			</ImagerySection>
			<ImagerySection name="TextHovered">
				<TextComponent color="FFFFFFFF" horzAlign="CENTER" vertAlign="MIDDLE" />
			</ImagerySection>
			<ImagerySection name="TextPushed">
				<TextComponent color="FFAAAAAA" horzAlign="CENTER" vertAlign="MIDDLE" />
			</ImagerySection>
			<StateImagery name="Normal">
				<Layer><Section section="FrameNormal" /></Layer>
				<Layer><Section section="TextNormal" /></Layer>
			</StateImagery>
			<StateImagery name="Hovered">
				<Layer><Section section="FrameHovered" /></Layer>
				<Layer><Section section="TextHovered" /></Layer>
			</StateImagery>
			<StateImagery name="Pushed">
				<Layer><Section section="FramePushed" /></Layer>
				<Layer><Section section="TextPushed" /></Layer>
			</StateImagery>
		</Visual>
		<Area><Size><AbsDimension x="24" y="24" /></Size></Area>
	</Frame>

	<!-- Title button template (clickable to open quest log) -->
	<Frame name="QuestTrackerTitleTemplate" type="Button" renderer="ButtonRenderer">
		<Property name="Font" value="DefaultSmall" />
		<Property name="HorzAlign" value="LEFT" />
		<Property name="VertAlign" value="TOP" />
		<Property name="TextColor" value="FFFFD100" />
		<Visual>
			<ImagerySection name="FrameNormal">
				<ImageComponent color="00000000" />
			</ImagerySection>
			<ImagerySection name="FrameHovered">
				<ImageComponent color="44FFFFFF" />
			</ImagerySection>
			<ImagerySection name="FramePushed">
				<ImageComponent color="22FFFFFF" />
			</ImagerySection>
			<ImagerySection name="Text">
				<TextComponent color="$TextColor" horzAlign="$HorzAlign" vertAlign="$VertAlign" />
			</ImagerySection>
			<StateImagery name="Normal">
				<Layer><Section section="FrameNormal" /></Layer>
				<Layer><Section section="Text" /></Layer>
			</StateImagery>
			<StateImagery name="Hovered">
				<Layer><Section section="FrameHovered" /></Layer>
				<Layer><Section section="Text" /></Layer>
			</StateImagery>
			<StateImagery name="Pushed">
				<Layer><Section section="FramePushed" /></Layer>
				<Layer><Section section="Text" /></Layer>
			</StateImagery>
		</Visual>
		<Area><Size><AbsDimension x="352" y="32" /></Size></Area>
	</Frame>

	<!-- Objective text template -->
	<Frame name="QuestTrackerObjTemplate" renderer="DefaultRenderer">
		<Property name="Font" value="SmallLabelFont" />
		<Property name="HorzAlign" value="LEFT" />
		<Property name="VertAlign" value="TOP" />
		<Property name="TextColor" value="FFAAAAAA" />
		<Visual>
			<ImagerySection name="Text">
				<TextComponent color="$TextColor" horzAlign="$HorzAlign" vertAlign="$VertAlign" />
			</ImagerySection>
			<StateImagery name="Enabled">
				<Layer><Section section="Text" /></Layer>
			</StateImagery>
		</Visual>
		<Area><Size><AbsDimension x="352" y="28" /></Size></Area>
	</Frame>

	<!-- Quest Tracker panel: anchored below the Minimap, right-aligned -->
	<Frame name="QuestTrackerFrame" parent="GameParent" renderer="DefaultRenderer">
		<Scripts>
			<OnLoad>
				return function(self)
					QuestTracker_OnLoad(self);
				end
			</OnLoad>
		</Scripts>
		<Visual>
			<ImagerySection name="Background">
				<ImageComponent color="BB000000" />
			</ImagerySection>
			<StateImagery name="Enabled">
				<Layer><Section section="Background" /></Layer>
			</StateImagery>
		</Visual>
		<Area>
			<Size><AbsDimension x="384" y="64" /></Size>
			<Anchor point="RIGHT" offset="0" />
			<Anchor point="TOP" relativePoint="BOTTOM" relativeTo="Minimap" offset="8" />
		</Area>

		<!-- Slot 1 -->
		<Frame name="QuestTrackerToggle1" inherits="QuestTrackerToggleTemplate" id="1">
			<Scripts>
				<OnClick>
					return function(self, button)
						QuestTracker_ToggleCollapse(1);
					end
				</OnClick>
			</Scripts>
		</Frame>
		<Frame name="QuestTrackerTitle1" inherits="QuestTrackerTitleTemplate" id="1">
			<Scripts>
				<OnClick>
					return function(self, button)
						QuestTracker_TitleClick(1);
					end
				</OnClick>
			</Scripts>
		</Frame>
		<Frame name="QuestTrackerObj1_1" inherits="QuestTrackerObjTemplate" />
		<Frame name="QuestTrackerObj1_2" inherits="QuestTrackerObjTemplate" />
		<Frame name="QuestTrackerObj1_3" inherits="QuestTrackerObjTemplate" />
		<Frame name="QuestTrackerObj1_4" inherits="QuestTrackerObjTemplate" />

		<!-- Slot 2 -->
		<Frame name="QuestTrackerToggle2" inherits="QuestTrackerToggleTemplate" id="2">
			<Scripts>
				<OnClick>
					return function(self, button)
						QuestTracker_ToggleCollapse(2);
					end
				</OnClick>
			</Scripts>
		</Frame>
		<Frame name="QuestTrackerTitle2" inherits="QuestTrackerTitleTemplate" id="2">
			<Scripts>
				<OnClick>
					return function(self, button)
						QuestTracker_TitleClick(2);
					end
				</OnClick>
			</Scripts>
		</Frame>
		<Frame name="QuestTrackerObj2_1" inherits="QuestTrackerObjTemplate" />
		<Frame name="QuestTrackerObj2_2" inherits="QuestTrackerObjTemplate" />
		<Frame name="QuestTrackerObj2_3" inherits="QuestTrackerObjTemplate" />
		<Frame name="QuestTrackerObj2_4" inherits="QuestTrackerObjTemplate" />

		<!-- Slot 3 -->
		<Frame name="QuestTrackerToggle3" inherits="QuestTrackerToggleTemplate" id="3">
			<Scripts>
				<OnClick>
					return function(self, button)
						QuestTracker_ToggleCollapse(3);
					end
				</OnClick>
			</Scripts>
		</Frame>
		<Frame name="QuestTrackerTitle3" inherits="QuestTrackerTitleTemplate" id="3">
			<Scripts>
				<OnClick>
					return function(self, button)
						QuestTracker_TitleClick(3);
					end
				</OnClick>
			</Scripts>
		</Frame>
		<Frame name="QuestTrackerObj3_1" inherits="QuestTrackerObjTemplate" />
		<Frame name="QuestTrackerObj3_2" inherits="QuestTrackerObjTemplate" />
		<Frame name="QuestTrackerObj3_3" inherits="QuestTrackerObjTemplate" />
		<Frame name="QuestTrackerObj3_4" inherits="QuestTrackerObjTemplate" />

		<!-- Slot 4 -->
		<Frame name="QuestTrackerToggle4" inherits="QuestTrackerToggleTemplate" id="4">
			<Scripts>
				<OnClick>
					return function(self, button)
						QuestTracker_ToggleCollapse(4);
					end
				</OnClick>
			</Scripts>
		</Frame>
		<Frame name="QuestTrackerTitle4" inherits="QuestTrackerTitleTemplate" id="4">
			<Scripts>
				<OnClick>
					return function(self, button)
						QuestTracker_TitleClick(4);
					end
				</OnClick>
			</Scripts>
		</Frame>
		<Frame name="QuestTrackerObj4_1" inherits="QuestTrackerObjTemplate" />
		<Frame name="QuestTrackerObj4_2" inherits="QuestTrackerObjTemplate" />
		<Frame name="QuestTrackerObj4_3" inherits="QuestTrackerObjTemplate" />
		<Frame name="QuestTrackerObj4_4" inherits="QuestTrackerObjTemplate" />

		<!-- Slot 5 -->
		<Frame name="QuestTrackerToggle5" inherits="QuestTrackerToggleTemplate" id="5">
			<Scripts>
				<OnClick>
					return function(self, button)
						QuestTracker_ToggleCollapse(5);
					end
				</OnClick>
			</Scripts>
		</Frame>
		<Frame name="QuestTrackerTitle5" inherits="QuestTrackerTitleTemplate" id="5">
			<Scripts>
				<OnClick>
					return function(self, button)
						QuestTracker_TitleClick(5);
					end
				</OnClick>
			</Scripts>
		</Frame>
		<Frame name="QuestTrackerObj5_1" inherits="QuestTrackerObjTemplate" />
		<Frame name="QuestTrackerObj5_2" inherits="QuestTrackerObjTemplate" />
		<Frame name="QuestTrackerObj5_3" inherits="QuestTrackerObjTemplate" />
		<Frame name="QuestTrackerObj5_4" inherits="QuestTrackerObjTemplate" />

	</Frame>
</UiLayout>
