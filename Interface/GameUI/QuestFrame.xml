<?xml version="1.0" ?>
<UiLayout xmlns="http://www.w3schools.com/Ui" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.w3schools.com/Ui.xsd file:///F:/mmo/data/client/Interface/Ui.xsd">
	<Script file="QuestFrame.lua" />

	<Font name="QuestTitleFont" file="Fonts/FRIZQT__.TTF" size="30" outline="0" />
	<Font name="QuestFont" file="Fonts/FRIZQT__.TTF" size="24" outline="0" />

    <Frame name="QuestFramePanelTemplate" renderer="DefaultRenderer" setAllPoints="true">
        <Property name="Visible" value="false" />

        <Visual>
            <ImagerySection name="Frame">
                <BorderComponent texture="Interface/GameUI/QuestFrame_Background.htex" borderSize="96" tint="FFFFFFFF">
                    <Area><Inset right="96" top="8" left="8" bottom="8" /></Area>
                </BorderComponent>
                <BorderComponent texture="Interface/GameUI/fg4_borders_01_19.htex" borderSize="25" />
            </ImagerySection>
            <StateImagery name="Enabled">
                <Layer>
                    <Section section="Frame" />
                </Layer>
            </StateImagery>
            <StateImagery name="Disabled">
                <Layer>
                    <Section section="Frame" />
                </Layer>
            </StateImagery>
        </Visual>
    </Frame>

    <Frame name="QuestMenuButtonTemplate" type="Button" renderer="ButtonRenderer">
        <Property name="Font" value="QuestFont" />
        <Property name="Icon" />
        <Property name="ClippedByParent" value="true" />

        <Visual>
			<ImagerySection name="BackgroundHighlight">
				<ImageComponent texture="Interface/GlueUI/CharSelectButtonHighlight.htex" tint="FFFACC12" tiling="VERTICAL">
					<Area><Inset all="4" /></Area>
				</ImageComponent>
			</ImagerySection>
			<ImagerySection name="BackgroundPressed">
				<ImageComponent texture="Interface/GlueUI/CharSelectButtonHighlight.htex" tint="FFFACC12" tiling="VERTICAL">
					<Area><Inset top="8" bottom="0" left="4" right="4" /></Area>
				</ImageComponent>
			</ImagerySection>
            <ImagerySection name="Icon">
                <ImageComponent tiling="NONE">
                    <Area><Inset all="6" /><Size><AbsDimension x="48" y="48" /></Size></Area>
					<PropertyValue property="Icon" />
                </ImageComponent>
            </ImagerySection>
			<ImagerySection name="TextDefault">
				<TextComponent color="FF100500" horzAlign="LEFT" vertAlign="CENTER">
					<Area><Inset left="64" /></Area>
                </TextComponent>
			</ImagerySection>
			<ImagerySection name="TextHovered">
				<TextComponent color="FF100500" horzAlign="LEFT" vertAlign="CENTER">
					<Area><Inset left="64" /></Area>
                </TextComponent>
			</ImagerySection>
			<ImagerySection name="TextPressed">
				<TextComponent color="FF100500" horzAlign="LEFT" vertAlign="CENTER">
					<Area><Inset left="64" /></Area>
                </TextComponent>
			</ImagerySection>
			
			<StateImagery name="Normal">
				<Layer>
                    <Section section="Icon" />
					<Section section="TextDefault" />
				</Layer>
			</StateImagery>
			<StateImagery name="Hovered">
				<Layer>
					<Section section="BackgroundHighlight" />
                    <Section section="Icon" />
					<Section section="TextHovered" />
				</Layer>
			</StateImagery>
			<StateImagery name="Pushed">
				<Layer>
					<Section section="BackgroundPressed" />
                    <Section section="Icon" />
					<Section section="TextPressed" />
				</Layer>
			</StateImagery>
			<StateImagery name="Disabled">
				<Layer>
                    <Section section="Icon" />
					<Section section="TextDefault" />
				</Layer>
			</StateImagery>
		</Visual>
		<Area>
			<Size><AbsDimension y="60" /></Size>
		</Area>
    </Frame>

	<!-- Bordered row holding one quest reward (icon slot + name). Sized from Lua; uses the
	     same border vocabulary as the quest panels so it reads well on the parchment. -->
	<Frame name="QuestRewardRowTemplate" renderer="DefaultRenderer">
		<Property name="ClippedByParent" value="true" />

		<Visual>
			<ImagerySection name="Background">
				<!-- Flat translucent fill: TransparentBorder.htex is a uniform dark texture
				     (the tooltip backdrop); the low tint alpha darkens the parchment subtly. -->
				<ImageComponent texture="Interface/GlueUI/TransparentBorder.htex" tiling="NONE" tint="40FFFFFF">
					<Area><Inset all="8" /></Area>
				</ImageComponent>
				<BorderComponent texture="Interface/GameUI/fg4_borders_01_19.htex" borderSize="25" />
			</ImagerySection>
			<StateImagery name="Enabled">
				<Layer>
					<Section section="Background" />
				</Layer>
			</StateImagery>
			<StateImagery name="Disabled">
				<Layer>
					<Section section="Background" />
				</Layer>
			</StateImagery>
		</Visual>

		<Area>
			<Size><AbsDimension y="128" /></Size>
		</Area>
	</Frame>

	<!-- Icon slot for a single quest reward (item or spell). Uses the CheckboxRenderer so the
	     offer-reward panel can mark the selected choice reward via SetChecked from Lua. The
	     button text renders the stack count in the lower right corner. -->
	<Frame name="QuestRewardSlotTemplate" type="Button" renderer="CheckboxRenderer">
		<Property name="Icon" />
		<Property name="Checkable" value="false" />

		<Visual>
			<ImagerySection name="Image">
				<ImageComponent tiling="NONE">
					<Area><Inset all="14" /></Area>
					<PropertyValue property="Icon" />
				</ImageComponent>
			</ImagerySection>
			<ImagerySection name="Count">
				<TextComponent color="FFFFFFFF" horzAlign="RIGHT" vertAlign="BOTTOM">
					<Area><Inset all="10" /></Area>
				</TextComponent>
			</ImagerySection>
			<ImagerySection name="NormalFrame">
				<BorderComponent texture="Interface/BW_ButtonSmall_Up.htex" borderSize="30" />
			</ImagerySection>
			<ImagerySection name="HoveredFrame">
				<BorderComponent texture="Interface/BW_ButtonSmall_Over.htex" borderSize="30" />
			</ImagerySection>
			<ImagerySection name="PushedFrame">
				<BorderComponent texture="Interface/BW_ButtonSmall_Down.htex" borderSize="30" />
			</ImagerySection>
			<ImagerySection name="SelectedFrame">
				<BorderComponent texture="Interface/BW_ButtonSmall_Over.htex" borderSize="30" tint="FFFACC12" />
			</ImagerySection>

			<StateImagery name="Normal">
				<Layer>
					<Section section="NormalFrame" />
					<Section section="Image" />
					<Section section="Count" />
				</Layer>
			</StateImagery>
			<StateImagery name="Hovered">
				<Layer>
					<Section section="HoveredFrame" />
					<Section section="Image" />
					<Section section="Count" />
				</Layer>
			</StateImagery>
			<StateImagery name="Pushed">
				<Layer>
					<Section section="PushedFrame" />
					<Section section="Image" />
					<Section section="Count" />
				</Layer>
			</StateImagery>
			<StateImagery name="Disabled">
				<Layer>
					<Section section="NormalFrame" />
					<Section section="Image" />
					<Section section="Count" />
				</Layer>
			</StateImagery>
			<StateImagery name="NormalChecked">
				<Layer>
					<Section section="SelectedFrame" />
					<Section section="Image" />
					<Section section="Count" />
				</Layer>
			</StateImagery>
			<StateImagery name="HoveredChecked">
				<Layer>
					<Section section="SelectedFrame" />
					<Section section="Image" />
					<Section section="Count" />
				</Layer>
			</StateImagery>
			<StateImagery name="PushedChecked">
				<Layer>
					<Section section="SelectedFrame" />
					<Section section="Image" />
					<Section section="Count" />
				</Layer>
			</StateImagery>
			<StateImagery name="DisabledChecked">
				<Layer>
					<Section section="SelectedFrame" />
					<Section section="Image" />
					<Section section="Count" />
				</Layer>
			</StateImagery>
		</Visual>

		<Area>
			<Size><AbsDimension x="96" y="96" /></Size>
		</Area>
	</Frame>

