<?xml version="1.0" ?>
<UiLayout xmlns="http://www.w3schools.com/Ui" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.w3schools.com/Ui.xsd file:///F:/mmo/data/client/Interface/Ui.xsd">
	<Script file="LootRollFrame.lua" />

	<Frame name="LootRollChoiceButtonTemplate" type="Button" inherits="GlueButton">
		<Property name="Font" value="SmallLabelFont" />
		<Area>
			<Size><AbsDimension x="92" y="40" /></Size>
		</Area>
	</Frame>

	<Frame name="LootRollItemTemplate" renderer="DefaultRenderer">
		<Area>
			<Size><AbsDimension x="520" y="72" /></Size>
		</Area>

		<Visual>
			<ImagerySection name="Background">
				<BorderComponent texture="Interface/GameUI/fg4_borders_simple.htex" borderSize="250" />
			</ImagerySection>
			<StateImagery name="Enabled">
				<Layer>
					<Section section="Background" />
				</Layer>
			</StateImagery>
		</Visual>

		<Frame name="Name" renderer="DefaultRenderer">
			<Property name="Font" value="DefaultSmall" />
			<Area>
				<Position><AbsDimension x="16" y="10" /></Position>
				<Size><AbsDimension x="250" y="20" /></Size>
			</Area>
		</Frame>

		<Frame name="Timer" renderer="DefaultRenderer">
			<Property name="Font" value="SmallLabelFont" />
			<Area>
				<Position><AbsDimension x="16" y="40" /></Position>
				<Size><AbsDimension x="120" y="20" /></Size>
			</Area>
		</Frame>

		<Frame name="NeedButton" inherits="LootRollChoiceButtonTemplate">
			<Property name="Text" value="Need" />
			<Area>
				<Position><AbsDimension x="230" y="16" /></Position>
			</Area>
		</Frame>

		<Frame name="GreedButton" inherits="LootRollChoiceButtonTemplate">
			<Property name="Text" value="Greed" />
			<Area>
				<Position><AbsDimension x="326" y="16" /></Position>
			</Area>
		</Frame>

		<Frame name="PassButton" inherits="LootRollChoiceButtonTemplate">
			<Property name="Text" value="Pass" />
			<Area>
				<Position><AbsDimension x="422" y="16" /></Position>
			</Area>
		</Frame>
	</Frame>

	<Frame name="LootRollFrame" parent="GameParent" renderer="DefaultRenderer">
		<Property name="Visible" value="false" />

		<Area>
			<Size><AbsDimension x="540" y="360" /></Size>
			<Anchor point="RIGHT" offset="-40" />
			<Anchor point="TOP" offset="180" />
		</Area>

		<Visual>
			<ImagerySection name="Background">
				<BorderComponent texture="Interface/GameUI/fg4_borders_simple.htex" borderSize="250" />
			</ImagerySection>
			<StateImagery name="Enabled">
				<Layer>
					<Section section="Background" />
				</Layer>
			</StateImagery>
		</Visual>

		<Scripts>
			<OnLoad>
				return function(self)
					LootRollFrame_OnLoad(self);
				end
			</OnLoad>
			<OnUpdate>
				return function(self, elapsed)
					LootRollFrame_OnUpdate(self, elapsed);
				end
			</OnUpdate>
		</Scripts>

		<Frame name="LootRollTitleBar" inherits="TitleBar">
			<Property name="Text" value="ROLL" />

			<Area>
				<Anchor point="TOP" offset="24" />
				<Anchor point="LEFT" offset="24" />
				<Anchor point="RIGHT" offset="-24" />
			</Area>
		</Frame>

		<Frame name="LootRollItem1" inherits="LootRollItemTemplate">
			<Area>
				<Anchor point="TOP" relativePoint="BOTTOM" relativeTo="LootRollTitleBar" offset="8" />
				<Anchor point="LEFT" offset="10" />
			</Area>
		</Frame>

		<Frame name="LootRollItem2" inherits="LootRollItemTemplate">
			<Area>
				<Anchor point="TOP" relativePoint="BOTTOM" relativeTo="LootRollItem1" offset="8" />
				<Anchor point="LEFT" offset="10" />
			</Area>
		</Frame>

		<Frame name="LootRollItem3" inherits="LootRollItemTemplate">
			<Area>
				<Anchor point="TOP" relativePoint="BOTTOM" relativeTo="LootRollItem2" offset="8" />
				<Anchor point="LEFT" offset="10" />
			</Area>
		</Frame>

		<Frame name="LootRollItem4" inherits="LootRollItemTemplate">
			<Area>
				<Anchor point="TOP" relativePoint="BOTTOM" relativeTo="LootRollItem3" offset="8" />
				<Anchor point="LEFT" offset="10" />
			</Area>
		</Frame>
	</Frame>
</UiLayout>