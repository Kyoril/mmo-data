<?xml version="1.0" ?>
<UiLayout xmlns="http://www.w3schools.com/Ui" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.w3schools.com/Ui.xsd file:///F:/mmo/data/client/Interface/Ui.xsd">
	<Script file="OptionsFrame.lua" />

	<!-- Category button template (radio-style: checked = selected) -->
	<Frame name="OptionsCatButtonTemplate" type="Button" renderer="CheckboxRenderer">
		<Property name="Font" value="DefaultSmall" />
		<Property name="Checkable" value="true" />

		<Visual>
			<ImagerySection name="NormalBg">
				<BorderComponent texture="Interface/GameUI/fg4_borders_01_19.htex" borderSize="25" tint="30000000" />
			</ImagerySection>
			<ImagerySection name="HoveredBg">
				<BorderComponent texture="Interface/GameUI/fg4_borders_01_19.htex" borderSize="25" tint="60332200" />
			</ImagerySection>
			<ImagerySection name="SelectedBg">
				<BorderComponent texture="Interface/GameUI/fg4_borders_01_28_2_result.htex" borderSize="24" />
			</ImagerySection>
			<ImagerySection name="CaptionNormal">
				<TextComponent color="FFD0D0D0" horzAlign="LEFT" vertAlign="CENTER">
					<Area><Inset left="20" /></Area>
				</TextComponent>
			</ImagerySection>
			<ImagerySection name="CaptionSelected">
				<TextComponent color="FFFFD100" horzAlign="LEFT" vertAlign="CENTER">
					<Area><Inset left="20" /></Area>
				</TextComponent>
			</ImagerySection>

			<StateImagery name="Normal">
				<Layer>
					<Section section="NormalBg" />
					<Section section="CaptionNormal" />
				</Layer>
			</StateImagery>
			<StateImagery name="Hovered">
				<Layer>
					<Section section="HoveredBg" />
					<Section section="CaptionNormal" />
				</Layer>
			</StateImagery>
			<StateImagery name="Pushed">
				<Layer>
					<Section section="HoveredBg" />
					<Section section="CaptionNormal" color="FFAAAAAA" />
				</Layer>
			</StateImagery>
			<StateImagery name="NormalChecked">
				<Layer>
					<Section section="SelectedBg" />
					<Section section="CaptionSelected" />
				</Layer>
			</StateImagery>
			<StateImagery name="HoveredChecked">
				<Layer>
					<Section section="SelectedBg" />
					<Section section="CaptionSelected" />
				</Layer>
			</StateImagery>
			<StateImagery name="PushedChecked">
				<Layer>
					<Section section="SelectedBg" />
					<Section section="CaptionSelected" color="FFAAAAAA" />
				</Layer>
			</StateImagery>
		</Visual>

		<Area>
			<Size><AbsDimension x="0" y="90" /></Size>
		</Area>
	</Frame>

	<!--
		Toggle row template.
		Child 0 = label text frame.
		Child 1 = checkbox button (icon-button style: frame border + icon when checked).
	-->
	<Frame name="OptionsToggleRowTemplate">
		<Area>
			<Size><AbsDimension x="0" y="96" /></Size>
		</Area>

		<!-- Child 0: row label -->
		<Frame name="OptionsToggleRowLabel" renderer="DefaultRenderer">
			<Property name="Font" value="DefaultSmall" />

			<Visual>
				<ImagerySection name="Text">
					<TextComponent color="FFD0D0D0" horzAlign="LEFT" vertAlign="CENTER" />
				</ImagerySection>
				<StateImagery name="Enabled">
					<Layer><Section section="Text" /></Layer>
				</StateImagery>
				<StateImagery name="Disabled">
					<Layer><Section section="Text" /></Layer>
				</StateImagery>
			</Visual>

			<Area>
				<Anchor point="LEFT" offset="16" />
				<Anchor point="TOP" />
				<Anchor point="BOTTOM" />
				<Size><AbsDimension x="900" /></Size>
			</Area>
		</Frame>

		<!--
			Child 1: icon-style checkbox button.
			Unchecked states: frame border only (empty inside).
			Checked states: frame border + Icon_QuestCompleted checkmark icon.
		-->
		<Frame name="OptionsToggleButton" type="Button" renderer="CheckboxRenderer">
			<Property name="Checkable" value="true" />

			<Visual>
				<!-- Button frame borders (same texture set as IconButton) -->
				<ImagerySection name="FrameNormal">
					<BorderComponent texture="Interface/GlueUI/CharButtonUp.htex" borderSize="22" />
				</ImagerySection>
				<ImagerySection name="FrameHovered">
					<BorderComponent texture="Interface/GlueUI/CharButtonHovered.htex" borderSize="22" />
				</ImagerySection>
				<ImagerySection name="FramePushed">
					<BorderComponent texture="Interface/GlueUI/CharButtonPushed.htex" borderSize="22" />
				</ImagerySection>

				<!-- Checkmark icon shown only in checked states -->
				<ImagerySection name="CheckIcon">
					<ImageComponent texture="Interface/Icons/fg4_iconsGold_checkMark_result.htex" tiling="NONE">
						<Area><Inset all="12" /></Area>
					</ImageComponent>
				</ImagerySection>

				<!-- Unchecked: frame only, no icon -->
				<StateImagery name="Normal">
					<Layer>
						<Section section="FrameNormal" />
					</Layer>
				</StateImagery>
				<StateImagery name="Hovered">
					<Layer>
						<Section section="FrameHovered" />
					</Layer>
				</StateImagery>
				<StateImagery name="Pushed">
					<Layer>
						<Section section="FramePushed" />
					</Layer>
				</StateImagery>

				<!-- Checked: frame + checkmark icon -->
				<StateImagery name="NormalChecked">
					<Layer>
						<Section section="FramePushed" />
						<Section section="CheckIcon" />
					</Layer>
				</StateImagery>
				<StateImagery name="HoveredChecked">
					<Layer>
						<Section section="FrameHovered" />
						<Section section="CheckIcon" />
					</Layer>
				</StateImagery>
				<StateImagery name="PushedChecked">
					<Layer>
						<Section section="FramePushed" />
						<Section section="CheckIcon" color="FFAAAAAA" />
					</Layer>
				</StateImagery>
			</Visual>

			<!-- Square checkbox, centered vertically in the 96px row -->
			<Area>
				<Anchor point="RIGHT" offset="-24" />
				<Anchor point="TOP" offset="8" />
				<Anchor point="BOTTOM" offset="-8" />
				<Size><AbsDimension x="80" /></Size>
			</Area>
		</Frame>
	</Frame>

	<!-- Dropdown row template: label (child 0) + combo box (child 1) -->
	<Frame name="OptionsComboRowTemplate">
		<Area>
			<Size><AbsDimension x="0" y="96" /></Size>
		</Area>

		<!-- Child 0: row label -->
		<Frame name="OptionsComboRowLabel" renderer="DefaultRenderer">
			<Property name="Font" value="DefaultSmall" />

			<Visual>
				<ImagerySection name="Text">
					<TextComponent color="FFD0D0D0" horzAlign="LEFT" vertAlign="CENTER" />
				</ImagerySection>
				<StateImagery name="Enabled">
					<Layer><Section section="Text" /></Layer>
				</StateImagery>
				<StateImagery name="Disabled">
					<Layer><Section section="Text" /></Layer>
				</StateImagery>
			</Visual>

			<Area>
				<Anchor point="LEFT" offset="16" />
				<Anchor point="TOP" />
				<Anchor point="BOTTOM" />
				<Size><AbsDimension x="700" /></Size>
			</Area>
		</Frame>

		<!-- Child 1: combo box -->
		<Frame name="OptionsComboBoxWidget" type="ComboBox" renderer="ComboBoxRenderer">
			<Property name="Font" value="DefaultSmall" />

			<Visual>
				<ImagerySection name="NormalBg">
					<BorderComponent texture="Interface/GameUI/fg4_borders_insetBlackSmall.htex" borderSize="11" />
				</ImagerySection>
				<ImagerySection name="HoveredBg">
					<BorderComponent texture="Interface/GameUI/fg4_borders_insetBlackSmall.htex" borderSize="11" tint="FFB07030" />
				</ImagerySection>
				<ImagerySection name="OpenBg">
					<BorderComponent texture="Interface/GameUI/fg4_borders_insetBlackSmall.htex" borderSize="11" tint="FFFFD100" />
				</ImagerySection>
				<ImagerySection name="DisabledBg">
					<BorderComponent texture="Interface/GameUI/fg4_borders_insetBlackSmall.htex" borderSize="11" tint="80404040" />
				</ImagerySection>
				<ImagerySection name="CaptionNormal">
					<TextComponent color="FFFFD100" horzAlign="LEFT" vertAlign="CENTER">
						<Area><Inset left="16" right="64" /></Area>
					</TextComponent>
				</ImagerySection>
				<ImagerySection name="CaptionHovered">
					<TextComponent color="FFFFFFFF" horzAlign="LEFT" vertAlign="CENTER">
						<Area><Inset left="16" right="64" /></Area>
					</TextComponent>
				</ImagerySection>
				<ImagerySection name="CaptionDisabled">
					<TextComponent color="AE888888" horzAlign="LEFT" vertAlign="CENTER">
						<Area><Inset left="16" right="64" /></Area>
					</TextComponent>
				</ImagerySection>

				<StateImagery name="Normal">
					<Layer>
						<Section section="NormalBg" />
						<Section section="CaptionNormal" />
					</Layer>
				</StateImagery>
				<StateImagery name="Hovered">
					<Layer>
						<Section section="HoveredBg" />
						<Section section="CaptionHovered" />
					</Layer>
				</StateImagery>
				<StateImagery name="Open">
					<Layer>
						<Section section="OpenBg" />
						<Section section="CaptionHovered" />
					</Layer>
				</StateImagery>
				<StateImagery name="Disabled">
					<Layer>
						<Section section="DisabledBg" />
						<Section section="CaptionDisabled" />
					</Layer>
				</StateImagery>
			</Visual>

			<Scripts>
				<OnClick>
					return function(self)
						ComboBox_Toggle(self);
					end
				</OnClick>
			</Scripts>

			<Area>
				<Anchor point="RIGHT" offset="-24" />
				<Anchor point="TOP" offset="12" />
				<Anchor point="BOTTOM" offset="-12" />
				<Size><AbsDimension x="400" /></Size>
			</Area>

			<!-- Arrow indicator child -->
			<Frame name="OptionsComboArrowIcon" renderer="DefaultRenderer">
				<Area>
					<Anchor point="TOP" offset="12" />
					<Anchor point="BOTTOM" offset="-12" />
					<Anchor point="RIGHT" offset="-12" />
					<Size><AbsDimension x="44" /></Size>
				</Area>
				<Visual>
					<ImagerySection name="Image">
						<ImageComponent texture="Interface/Icons/IconGold_ArrowDown.htex" tiling="NONE" />
					</ImagerySection>
					<StateImagery name="Enabled">
						<Layer><Section section="Image" /></Layer>
					</StateImagery>
				</Visual>
			</Frame>
		</Frame>
	</Frame>

	<!--
		Slider row template (e.g. volume settings).
		Child 0 = label text frame.
		Child 1 = horizontal ScrollBar used as slider (children: left button, right button, thumb).
		Child 2 = value text frame (e.g. "80%").
	-->
	<Frame name="OptionsSliderRowTemplate">
		<Area>
			<Size><AbsDimension x="0" y="96" /></Size>
		</Area>

		<!-- Child 0: row label -->
		<Frame name="OptionsSliderRowLabel" renderer="DefaultRenderer">
			<Property name="Font" value="DefaultSmall" />

			<Visual>
				<ImagerySection name="Text">
					<TextComponent color="FFD0D0D0" horzAlign="LEFT" vertAlign="CENTER" />
				</ImagerySection>
				<StateImagery name="Enabled">
					<Layer><Section section="Text" /></Layer>
				</StateImagery>
				<StateImagery name="Disabled">
					<Layer><Section section="Text" /></Layer>
				</StateImagery>
			</Visual>

			<Area>
				<Anchor point="LEFT" offset="16" />
				<Anchor point="TOP" />
				<Anchor point="BOTTOM" />
				<Size><AbsDimension x="700" /></Size>
			</Area>
		</Frame>

		<!-- Child 1: horizontal slider built from the scroll bar widget -->
		<Frame name="OptionsSliderWidget" type="ScrollBar" renderer="DefaultRenderer">
			<Property name="Orientation" value="HORIZONTAL" />

			<Visual>
				<ImagerySection name="Border">
					<BorderComponent texture="Interface/GameUI/fg4_borders_01_19.htex" borderSize="25" />
				</ImagerySection>
				<StateImagery name="Enabled">
					<Layer><Section section="Border" /></Layer>
				</StateImagery>
				<StateImagery name="Disabled">
					<Layer><Section section="Border" /></Layer>
				</StateImagery>
			</Visual>

			<Area>
				<Anchor point="RIGHT" offset="-24" />
				<Anchor point="TOP" offset="8" />
				<Anchor point="BOTTOM" offset="-8" />
				<Size><AbsDimension x="400" /></Size>
			</Area>

			<Frame name="SliderLeftButton" inherits="GlueButton">
				<Property name="Icon" value="Interface/Icons/fg4_iconsGold_leftArrow.htex" />
				<Area>
					<Anchor point="LEFT" offset="8" />
					<Anchor point="TOP" offset="8" />
					<Size><AbsDimension x="64" y="64" /></Size>
				</Area>
			</Frame>

			<Frame name="SliderRightButton" inherits="GlueButton">
				<Property name="Icon" value="Interface/Icons/fg4_iconsGold_rightArrow.htex" />
				<Area>
					<Anchor point="RIGHT" offset="-8" />
					<Anchor point="TOP" offset="8" />
					<Size><AbsDimension x="64" y="64" /></Size>
				</Area>
			</Frame>

			<Frame name="SliderThumb" inherits="ThumbButtonTemplate">
				<Area>
					<Anchor point="LEFT" offset="72" />
					<Anchor point="TOP" offset="8" />
					<Size><AbsDimension x="64" y="64" /></Size>
				</Area>
			</Frame>
		</Frame>

		<!-- Child 2: current value label -->
		<Frame name="OptionsSliderValueLabel" renderer="DefaultRenderer">
			<Property name="Font" value="DefaultSmall" />

			<Visual>
				<ImagerySection name="Text">
					<TextComponent color="FFFFD100" horzAlign="RIGHT" vertAlign="CENTER" />
				</ImagerySection>
				<StateImagery name="Enabled">
					<Layer><Section section="Text" /></Layer>
				</StateImagery>
				<StateImagery name="Disabled">
					<Layer><Section section="Text" /></Layer>
				</StateImagery>
			</Visual>

			<Area>
				<Anchor point="RIGHT" offset="-440" />
				<Anchor point="TOP" />
				<Anchor point="BOTTOM" />
				<Size><AbsDimension x="140" /></Size>
			</Area>
		</Frame>
	</Frame>

	<!--
		Key-binding category header row (full-width label with gold title text).
	-->
	<Frame name="KeyBindCatRowTemplate">
		<Area>
			<Size><AbsDimension x="0" y="52" /></Size>
		</Area>

		<Frame name="KeyBindCatLabel" renderer="DefaultRenderer">
			<Property name="Font" value="Default" />

			<Visual>
				<ImagerySection name="Bg">
					<BorderComponent texture="Interface/GameUI/fg4_borders_01_19.htex" borderSize="25" tint="60331100" />
				</ImagerySection>
				<ImagerySection name="Text">
					<TextComponent color="FFFFD100" horzAlign="LEFT" vertAlign="CENTER">
						<Area><Inset left="20" /></Area>
					</TextComponent>
				</ImagerySection>
				<StateImagery name="Enabled">
					<Layer>
						<Section section="Bg" />
						<Section section="Text" />
