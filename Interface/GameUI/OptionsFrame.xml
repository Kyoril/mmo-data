			<Size><AbsDimension x="0" y="72" /></Size>
		</Area>

		<!-- Child 0: Action label -->
		<Frame name="KeyBindRowLabel" renderer="DefaultRenderer">
			<Property name="Font" value="DefaultSmall" />

			<Visual>
				<ImagerySection name="Text">
					<TextComponent color="FFD0D0D0" horzAlign="LEFT" vertAlign="CENTER" />
				</ImagerySection>
				<StateImagery name="Enabled">
					<Layer><Section section="Text" /></Layer>
				</StateImagery>
				<StateImagery name="Disabled">
					<Layer><Section section="Text" /></Layer>
				</StateImagery>
			</Visual>

			<!-- Leave 448px on the right for the two 216px buttons + gaps -->
			<Area>
				<Anchor point="LEFT" offset="16" />
				<Anchor point="TOP" />
				<Anchor point="BOTTOM" />
				<Anchor point="RIGHT" offset="-456" />
			</Area>
		</Frame>

