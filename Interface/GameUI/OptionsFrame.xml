			</Visual>

			<Area>
				<Anchor point="RIGHT" relativePoint="RIGHT" offset="-232" />
				<Anchor point="TOP" offset="8" />
				<Anchor point="BOTTOM" offset="-8" />
				<Size><AbsDimension x="216" /></Size>
			</Area>
