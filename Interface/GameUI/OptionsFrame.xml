				<ImagerySection name="CaptionPushed">
					<TextComponent color="FFAAAAAA" horzAlign="CENTER" vertAlign="CENTER" />
				</ImagerySection>

				<StateImagery name="Normal">
					<Layer>
						<Section section="NormalBg" />
						<Section section="Caption" />
					</Layer>
				</StateImagery>
				<StateImagery name="Hovered">
					<Layer>
						<Section section="HoveredBg" />
